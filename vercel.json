{
  "version": 2,
  "functions": {
    "MyProject/wsgi.py": {
      "maxDuration": 15
    }
  },
  "builds": [
    {
      "src": "MyProject/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.10" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "MyProject/wsgi.py"
    }
  ],
  "buildCommand": null,
  "env": {
    "DJANGO_SETTINGS_MODULE": "MyProject.settings",
    "PYTHONPATH": ".",
    "VERCEL": "1"
  }
}

